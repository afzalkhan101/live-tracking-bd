<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <template id="salesperson_dashboard" name="Salesperson Live Tracking Dashboard">
    <t t-call="web.layout">

      <t t-set="head">
        <link rel="preconnect" href="https://fonts.googleapis.com"/>
        <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&amp;family=DM+Mono:wght@400;500&amp;display=swap" rel="stylesheet"/>
        <style>
          :root {
            --bg:        #0d0f14;
            --surface:   #13161e;
            --surface2:  #1b1f2b;
            --border:    rgba(255,255,255,0.07);
            --accent:    #4f8ef7;
            --accent2:   #6ee7b7;
            --warn:      #f59e0b;
            --danger:    #f87171;
            --text:      #e8eaf0;
            --muted:     #6b7280;
            --live:      #22c55e;
            --idle:      #f59e0b;
            --offline:   #4b5563;
            --radius:    14px;
            --radius-sm: 8px;
          }

          *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

          body {
            background: var(--bg);
            color: var(--text);
            font-family: 'DM Sans', sans-serif;
            font-size: 14px;
            min-height: 100vh;
            overflow-x: hidden;
          }

          ::-webkit-scrollbar { width: 6px; }
          ::-webkit-scrollbar-track { background: var(--bg); }
          ::-webkit-scrollbar-thumb { background: var(--surface2); border-radius: 4px; }

          .layout { display: flex; min-height: 100vh; }

          /* ── Sidebar ── */
          .sidebar {
            width: 64px;
            background: var(--surface);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px 0;
            gap: 6px;
            position: fixed;
            top: 0; left: 0; bottom: 0;
            z-index: 100;
          }
          .logo {
            width: 36px; height: 36px;
            background: var(--accent);
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 18px;
            margin-bottom: 16px;
          }
          .nav-item {
            width: 44px; height: 44px;
            border-radius: var(--radius-sm);
            display: flex; align-items: center; justify-content: center;
            cursor: pointer;
            color: var(--muted);
            transition: all .2s;
            font-size: 18px;
            position: relative;
          }
          .nav-item:hover { background: var(--surface2); color: var(--text); }
          .nav-item.active { background: rgba(79,142,247,.15); color: var(--accent); }
          .nav-item.active::before {
            content: '';
            position: absolute; left: -1px;
            width: 3px; height: 24px;
            background: var(--accent);
            border-radius: 0 4px 4px 0;
          }
          .sidebar-bottom { margin-top: auto; display: flex; flex-direction: column; align-items: center; gap: 6px; }
          .avatar {
            width: 32px; height: 32px;
            border-radius: 50%;
            background: linear-gradient(135deg, #4f8ef7, #6ee7b7);
            display: flex; align-items: center; justify-content: center;
            font-size: 12px; font-weight: 600;
            cursor: pointer;
          }

          /* ── Main ── */
          .main { margin-left: 64px; flex: 1; display: flex; flex-direction: column; }

          /* ── Topbar ── */
          .topbar {
            height: 60px;
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center;
            padding: 0 28px;
            gap: 16px;
            position: sticky; top: 0; z-index: 50;
          }
          .topbar h1 { font-size: 16px; font-weight: 600; flex: 1; }
          .topbar-badge {
            background: rgba(34,197,94,.1);
            color: var(--live);
            font-size: 11px; font-weight: 600;
            padding: 3px 10px;
            border-radius: 100px;
            border: 1px solid rgba(34,197,94,.25);
            display: flex; align-items: center; gap: 5px;
          }
          .topbar-badge::before {
            content: '';
            width: 7px; height: 7px;
            background: var(--live);
            border-radius: 50%;
            animation: pulse 1.8s infinite;
          }
          @keyframes pulse {
            0%,100% { opacity: 1; transform: scale(1); }
            50%      { opacity: .5; transform: scale(1.3); }
          }
          .search-box {
            background: var(--surface2);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            display: flex; align-items: center; gap: 8px;
            padding: 7px 12px;
            width: 220px;
          }
          .search-box input {
            background: none; border: none; outline: none;
            color: var(--text); font-family: inherit; font-size: 13px; width: 100%;
          }
          .search-box input::placeholder { color: var(--muted); }
          .icon-btn {
            width: 36px; height: 36px;
            border-radius: var(--radius-sm);
            background: var(--surface2);
            border: 1px solid var(--border);
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; color: var(--muted);
            transition: all .2s; font-size: 16px;
          }
          .icon-btn:hover { color: var(--text); border-color: rgba(255,255,255,.15); }

          /* ── Content ── */
          .content { padding: 24px 28px; flex: 1; }

          /* ── Stat cards ── */
          .stat-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px; }
          .stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 20px;
            position: relative; overflow: hidden;
            transition: transform .2s, border-color .2s;
            cursor: default;
          }
          .stat-card:hover { transform: translateY(-2px); border-color: rgba(255,255,255,.12); }
          .stat-card::after {
            content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
          }
          .stat-card.blue::after  { background: var(--accent); }
          .stat-card.green::after { background: var(--live); }
          .stat-card.warn::after  { background: var(--warn); }
          .stat-card.red::after   { background: var(--danger); }
          .stat-label { font-size: 11px; font-weight: 500; color: var(--muted); letter-spacing: .6px; text-transform: uppercase; margin-bottom: 8px; }
          .stat-value { font-size: 32px; font-weight: 700; line-height: 1; font-family: 'DM Mono', monospace; }
          .stat-sub   { font-size: 12px; color: var(--muted); margin-top: 6px; }
          .stat-icon  { position: absolute; right: 20px; top: 20px; font-size: 28px; opacity: .12; }
          .delta {
            display: inline-flex; align-items: center; gap: 3px;
            font-size: 11px; font-weight: 600;
            padding: 2px 6px; border-radius: 4px; margin-top: 6px;
          }
          .delta.up   { background: rgba(34,197,94,.1);  color: var(--live); }
          .delta.down { background: rgba(248,113,113,.1); color: var(--danger); }

          /* ── Mid grid ── */
          .mid-grid { display: grid; grid-template-columns: 1fr 340px; gap: 20px; margin-bottom: 24px; }

          .map-card {
            background: var(--surface); border: 1px solid var(--border);
            border-radius: var(--radius); overflow: hidden;
          }
          .card-header {
            padding: 16px 20px; border-bottom: 1px solid var(--border);
            display: flex; align-items: center; gap: 10px;
          }
          .card-header h2 { font-size: 14px; font-weight: 600; flex: 1; }
          .chip { font-size: 11px; font-weight: 600; padding: 3px 9px; border-radius: 100px; }
          .chip.live    { background: rgba(34,197,94,.12);  color: var(--live);  border: 1px solid rgba(34,197,94,.25); }
          .chip.idle    { background: rgba(245,158,11,.12); color: var(--warn);  border: 1px solid rgba(245,158,11,.25); }
          .chip.offline { background: rgba(107,114,128,.12); color: var(--muted); border: 1px solid rgba(107,114,128,.25); }

          .map-container { height: 320px; background: var(--surface2); position: relative; overflow: hidden; }
          .map-svg { width: 100%; height: 100%; }
          .map-overlay {
            position: absolute; bottom: 12px; left: 12px;
            background: rgba(13,15,20,.85); backdrop-filter: blur(8px);
            border: 1px solid var(--border); border-radius: var(--radius-sm);
            padding: 10px 14px; font-size: 11px; color: var(--muted);
          }
          .map-overlay strong { color: var(--text); font-size: 12px; }

          /* ── Activity ── */
          .activity-card {
            background: var(--surface); border: 1px solid var(--border);
            border-radius: var(--radius); overflow: hidden;
          }
          .activity-list { overflow-y: auto; max-height: 350px; }
          .activity-item {
            padding: 12px 20px; border-bottom: 1px solid var(--border);
            display: flex; align-items: flex-start; gap: 12px;
            transition: background .15s;
          }
          .activity-item:hover { background: rgba(255,255,255,.02); }
          .activity-item:last-child { border-bottom: none; }
          .activity-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; margin-top: 5px; }
          .activity-text { flex: 1; }
          .activity-name { font-weight: 500; color: var(--text); font-size: 13px; }
          .activity-desc { color: var(--muted); font-size: 12px; margin-top: 2px; }
          .activity-time { font-size: 11px; color: var(--muted); font-family: 'DM Mono', monospace; flex-shrink: 0; }

          /* ── Bottom grid ── */
          .bottom-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 20px; }

          .table-card {
            background: var(--surface); border: 1px solid var(--border);
            border-radius: var(--radius); overflow: hidden;
          }
          table { width: 100%; border-collapse: collapse; }
          thead th {
            padding: 11px 16px; text-align: left;
            font-size: 11px; font-weight: 600; color: var(--muted);
            letter-spacing: .5px; text-transform: uppercase;
            border-bottom: 1px solid var(--border); background: var(--surface2);
          }
          tbody tr { transition: background .15s; }
          tbody tr:hover { background: rgba(255,255,255,.025); }
          tbody td {
            padding: 12px 16px; font-size: 13px;
            border-bottom: 1px solid var(--border); vertical-align: middle;
          }
          tbody tr:last-child td { border-bottom: none; }

          .user-cell { display: flex; align-items: center; gap: 10px; }
          .user-avatar {
            width: 30px; height: 30px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 11px; font-weight: 700; flex-shrink: 0;
          }
          .user-name { font-weight: 500; }
          .user-team { font-size: 11px; color: var(--muted); }

          .status-dot { display: inline-flex; align-items: center; gap: 5px; font-size: 12px; font-weight: 500; }
          .status-dot::before { content: ''; width: 7px; height: 7px; border-radius: 50%; }
          .status-dot.live::before    { background: var(--live); box-shadow: 0 0 6px var(--live); }
          .status-dot.idle::before    { background: var(--idle); }
          .status-dot.offline::before { background: var(--offline); }
          .status-dot.live    { color: var(--live); }
          .status-dot.idle    { color: var(--idle); }
          .status-dot.offline { color: var(--muted); }

          .state-badge { display: inline-block; font-size: 11px; font-weight: 600; padding: 3px 8px; border-radius: 4px; }
          .state-accepted { background: rgba(79,142,247,.12);  color: var(--accent); }
          .state-planned  { background: rgba(245,158,11,.12);  color: var(--warn); }
          .state-done     { background: rgba(110,231,183,.12); color: var(--accent2); }
          .state-rejected { background: rgba(248,113,113,.12); color: var(--danger); }

          .progress-bar { width: 80px; height: 6px; background: var(--surface2); border-radius: 3px; overflow: hidden; }
          .progress-fill {
            height: 100%; border-radius: 3px;
            background: linear-gradient(90deg, var(--accent), var(--accent2));
            transition: width .6s ease;
          }
          .progress-fill.warn   { background: linear-gradient(90deg, var(--warn), #fbbf24); }
          .progress-fill.danger { background: linear-gradient(90deg, var(--danger), #f87171); }
          .mono { font-family: 'DM Mono', monospace; }

          /* ── KPI card ── */
          .kpi-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
          .donut-wrap { padding: 20px; display: flex; flex-direction: column; align-items: center; }
          .donut-svg { width: 140px; height: 140px; }
          .kpi-legend { width: 100%; margin-top: 16px; }
          .kpi-legend-item {
            display: flex; align-items: center; justify-content: space-between;
            padding: 8px 0; border-bottom: 1px solid var(--border); font-size: 13px;
          }
          .kpi-legend-item:last-child { border-bottom: none; }
          .legend-dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; margin-right: 8px; }
          .legend-left { display: flex; align-items: center; color: var(--muted); }
          .legend-val  { font-weight: 600; font-family: 'DM Mono', monospace; }

          .expense-row {
            display: grid; grid-template-columns: repeat(3, 1fr);
            gap: 12px; padding: 16px 20px; border-top: 1px solid var(--border);
          }
          .exp-item { text-align: center; }
          .exp-label { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: .5px; }
          .exp-val   { font-size: 18px; font-weight: 700; font-family: 'DM Mono', monospace; margin-top: 4px; }

          /* ── Animations ── */
          @keyframes fadeUp {
            from { opacity: 0; transform: translateY(16px); }
            to   { opacity: 1; transform: translateY(0); }
          }
          .stat-card { animation: fadeUp .4s ease both; }
          .stat-card:nth-child(1) { animation-delay: .05s; }
          .stat-card:nth-child(2) { animation-delay: .10s; }
          .stat-card:nth-child(3) { animation-delay: .15s; }
          .stat-card:nth-child(4) { animation-delay: .20s; }
          .mid-grid    { animation: fadeUp .4s .25s ease both; }
          .bottom-grid { animation: fadeUp .4s .35s ease both; }

          /* ── Tooltip ── */
          [data-tip] { position: relative; }
          [data-tip]:hover::after {
            content: attr(data-tip);
            position: absolute; bottom: calc(100% + 6px); left: 50%;
            transform: translateX(-50%);
            background: #1e2230; border: 1px solid var(--border);
            color: var(--text); font-size: 11px;
            padding: 4px 8px; border-radius: 4px;
            white-space: nowrap; z-index: 999;
          }

          @media (max-width: 1100px) {
            .stat-row    { grid-template-columns: repeat(2, 1fr); }
            .mid-grid    { grid-template-columns: 1fr; }
            .bottom-grid { grid-template-columns: 1fr; }
          }
        </style>
      </t>

      <t t-set="body">
        <div class="layout">

          <!-- Sidebar -->
          <nav class="sidebar">
            <div class="logo">&#128205;</div>
            <div class="nav-item active" data-tip="Dashboard">&#128506;</div>
            <div class="nav-item" data-tip="Salespersons">&#128101;</div>
            <div class="nav-item" data-tip="Visit Plans">&#128203;</div>
            <div class="nav-item" data-tip="Check-ins">&#9989;</div>
            <div class="nav-item" data-tip="KPIs">&#128202;</div>
            <div class="nav-item" data-tip="Reports">&#128196;</div>
            <div class="sidebar-bottom">
              <div class="nav-item" data-tip="Settings">&#9881;</div>
              <div class="avatar" data-tip="Admin">AD</div>
            </div>
          </nav>

          <!-- Main -->
          <div class="main">

            <!-- Topbar -->
            <header class="topbar">
              <h1>Live Tracking Dashboard</h1>
              <div class="topbar-badge" id="live-badge">6 Active Now</div>
              <div class="search-box">
                <span>&#128269;</span>
                <input type="text" placeholder="Search salesperson&#8230;"/>
              </div>
              <div class="icon-btn" data-tip="Refresh">&#128260;</div>
              <div class="icon-btn" data-tip="Notifications">&#128276;</div>
            </header>

            <!-- Content -->
            <div class="content">

              <!-- Stat cards -->
              <div class="stat-row">
                <div class="stat-card blue">
                  <div class="stat-label">Total Field Reps</div>
                  <div class="stat-value">24</div>
                  <div class="stat-icon">&#128100;</div>
                  <div class="delta up">&#9650; 3 this month</div>
                </div>
                <div class="stat-card green">
                  <div class="stat-label">Live Right Now</div>
                  <div class="stat-value" style="color:var(--live)">6</div>
                  <div class="stat-icon">&#128994;</div>
                  <div class="stat-sub">4 idle &#183; 14 offline</div>
                </div>
                <div class="stat-card warn">
                  <div class="stat-label">Today's Visits Planned</div>
                  <div class="stat-value" style="color:var(--warn)">42</div>
                  <div class="stat-icon">&#128203;</div>
                  <div class="delta up">&#9650; 28 covered</div>
                </div>
                <div class="stat-card red">
                  <div class="stat-label">Route Deviation Alerts</div>
                  <div class="stat-value" style="color:var(--danger)">3</div>
                  <div class="stat-icon">&#9888;</div>
                  <div class="delta down">&#9660; 2 pending review</div>
                </div>
              </div>

              <!-- Mid grid -->
              <div class="mid-grid">

                <!-- Map card -->
                <div class="map-card">
                  <div class="card-header">
                    <h2>Live Field Map</h2>
                    <span class="chip live">6 Live</span>
                    <span class="chip idle">4 Idle</span>
                    <span class="chip offline">14 Offline</span>
                  </div>
                  <div class="map-container">
                    <svg class="map-svg" viewBox="0 0 700 320" xmlns="http://www.w3.org/2000/svg">
                      <defs>
                        <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
                          <path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
                        </pattern>
                        <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="0%">
                          <stop offset="0%" stop-color="#4f8ef7"/>
                          <stop offset="100%" stop-color="#6ee7b7"/>
                        </linearGradient>
                      </defs>
                      <rect width="700" height="320" fill="#13161e"/>
                      <rect width="700" height="320" fill="url(#grid)"/>
                      <!-- Roads -->
                      <rect x="0" y="140" width="700" height="14" fill="rgba(255,255,255,0.04)" rx="2"/>
                      <rect x="320" y="0" width="14" height="320" fill="rgba(255,255,255,0.04)" rx="2"/>
                      <rect x="0" y="240" width="700" height="8" fill="rgba(255,255,255,0.025)" rx="2"/>
                      <rect x="500" y="0" width="8" height="320" fill="rgba(255,255,255,0.025)" rx="2"/>
                      <rect x="120" y="0" width="8" height="320" fill="rgba(255,255,255,0.025)" rx="2"/>
                      <!-- Blocks -->
                      <rect x="30"  y="20"  width="80"  height="110" fill="rgba(79,142,247,.05)" rx="4"/>
                      <rect x="140" y="20"  width="165" height="110" fill="rgba(79,142,247,.04)" rx="4"/>
                      <rect x="340" y="20"  width="145" height="110" fill="rgba(79,142,247,.04)" rx="4"/>
                      <rect x="530" y="20"  width="150" height="110" fill="rgba(79,142,247,.04)" rx="4"/>
                      <rect x="30"  y="164" width="80"  height="60"  fill="rgba(79,142,247,.04)" rx="4"/>
                      <rect x="140" y="164" width="165" height="60"  fill="rgba(79,142,247,.04)" rx="4"/>
                      <rect x="340" y="164" width="145" height="60"  fill="rgba(79,142,247,.04)" rx="4"/>
                      <rect x="530" y="164" width="150" height="60"  fill="rgba(79,142,247,.04)" rx="4"/>
                      <!-- Route lines -->
                      <polyline points="100,147 200,147 327,100 327,20" fill="none" stroke="rgba(79,142,247,.3)"   stroke-width="2" stroke-dasharray="6 4"/>
                      <polyline points="420,147 500,60"                  fill="none" stroke="rgba(110,231,183,.2)" stroke-width="2" stroke-dasharray="6 4"/>
                      <!-- Live pins -->
                      <g transform="translate(100,130)">
                        <circle r="12" fill="rgba(34,197,94,.15)" stroke="#22c55e" stroke-width="1.5"/>
                        <circle r="5"  fill="#22c55e"/>
                        <circle r="14" fill="none" stroke="rgba(34,197,94,.4)" stroke-width="1">
                          <animate attributeName="r"       values="12;20;12" dur="2s"   repeatCount="indefinite"/>
                          <animate attributeName="opacity" values="0.5;0;0.5" dur="2s"   repeatCount="indefinite"/>
                        </circle>
                      </g>
                      <g transform="translate(200,147)">
                        <circle r="12" fill="rgba(34,197,94,.15)" stroke="#22c55e" stroke-width="1.5"/>
                        <circle r="5"  fill="#22c55e"/>
                        <circle r="14" fill="none" stroke="rgba(34,197,94,.4)" stroke-width="1">
                          <animate attributeName="r"       values="12;20;12" dur="2.4s" repeatCount="indefinite"/>
                          <animate attributeName="opacity" values="0.5;0;0.5" dur="2.4s" repeatCount="indefinite"/>
                        </circle>
                      </g>
                      <g transform="translate(420,147)">
                        <circle r="12" fill="rgba(34,197,94,.15)" stroke="#22c55e" stroke-width="1.5"/>
                        <circle r="5"  fill="#22c55e"/>
                      </g>
                      <g transform="translate(580,60)">
                        <circle r="12" fill="rgba(34,197,94,.15)" stroke="#22c55e" stroke-width="1.5"/>
                        <circle r="5"  fill="#22c55e"/>
                      </g>
                      <g transform="translate(60,200)">
                        <circle r="12" fill="rgba(34,197,94,.15)" stroke="#22c55e" stroke-width="1.5"/>
                        <circle r="5"  fill="#22c55e"/>
                      </g>
                      <g transform="translate(340,260)">
                        <circle r="12" fill="rgba(34,197,94,.15)" stroke="#22c55e" stroke-width="1.5"/>
                        <circle r="5"  fill="#22c55e"/>
                      </g>
                      <!-- Idle pins -->
                      <g transform="translate(327,60)">
                        <circle r="10" fill="rgba(245,158,11,.15)" stroke="#f59e0b" stroke-width="1.5"/>
                        <circle r="4"  fill="#f59e0b"/>
                      </g>
                      <g transform="translate(500,200)">
                        <circle r="10" fill="rgba(245,158,11,.15)" stroke="#f59e0b" stroke-width="1.5"/>
                        <circle r="4"  fill="#f59e0b"/>
                      </g>
                      <g transform="translate(155,200)">
                        <circle r="10" fill="rgba(245,158,11,.15)" stroke="#f59e0b" stroke-width="1.5"/>
                        <circle r="4"  fill="#f59e0b"/>
                      </g>
                      <!-- Labels -->
                      <text x="108" y="120" fill="white" font-size="9" font-family="DM Sans" opacity=".7">Karim</text>
                      <text x="208" y="137" fill="white" font-size="9" font-family="DM Sans" opacity=".7">Rahim</text>
                      <text x="428" y="137" fill="white" font-size="9" font-family="DM Sans" opacity=".7">Sadia</text>
                      <text x="588" y="50"  fill="white" font-size="9" font-family="DM Sans" opacity=".7">Nabil</text>
